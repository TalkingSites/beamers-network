<nav class="navbar" id="navbar-main">
  <div class="container d-flex align-items-center justify-content-between gap-3 py-2">

    <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" href="/">
      <span class="navbar-brand-name">Beamers Network</span>
    </a>

    <div class="d-flex align-items-center gap-2 ms-auto">
      <div class="collapse navbar-collapse" id="nav">
        <ul class="navbar-nav d-flex flex-row align-items-center gap-1">
          {% for item in navbar %}
            {% if item.title != "Apply" %}
            <li class="nav-item">
              <a class="nav-link{% if page.url == item.href %} active{% endif %}" href="{{ item.href }}">
                {{ item.title }}
              </a>
            </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <a href="/apply/" class="btn-apply-nav d-none d-sm-inline-flex">
        Apply
      </a>

      <button class="navbar-toggler border-0 d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-label="Menu">
        <i class="bi bi-list" style="font-size:1.4rem; color:var(--text-primary);"></i>
      </button>
    </div>

  </div>
</nav>
